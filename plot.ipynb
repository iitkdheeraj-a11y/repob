   "source": [
    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "# Create a sample DataFrame\n",
    "data = {'Month': [5, 6, 7, 8, 9],\n",
    "        'Temp': [20, 35, 50, 30, 25]}\n",
    "df = pd.DataFrame(data)\n",
    "\n",
    "# Simple line plot\n",
    "df.plot(kind='line', x='Month', y='Temp', title='Temp vs month')\n",
    "plt.show()"
   ]
